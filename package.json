{
  "name": "sync-app",
  "version": "1.0.0",
  "description": "Material 3 Calendar, Contacts, and Notes Syncing App",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "backend:dev": "nodemon server.js",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run frontend:build",
    "install-all": "npm install && npm install --prefix frontend"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7"
  }
}
